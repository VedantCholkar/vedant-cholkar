---
// index.astro — Vedant Cholkar · Cybersecurity
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vedant Cholkar — Cybersecurity</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <script src="https://unpkg.com/@studio-freight/lenis@1.0.39/dist/lenis.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #0a0a0b;
      --fg:       #ede8e0;
      --dim:      rgba(237,232,224,0.72);
      --dim2:     rgba(237,232,224,0.50);
      --glass-bg: rgba(237,232,224,0.045);
      --glass-b:  rgba(237,232,224,0.12);
      --glass-bt: rgba(237,232,224,0.28);
      --accent:   #E5533D;
      --serif:    'Cormorant', Georgia, serif;
      --sans:     'DM Sans', sans-serif;
      --mono:     'Space Mono', monospace;
      --ease:     cubic-bezier(0.16, 1, 0.3, 1);
      --pad:      clamp(32px, 7vw, 96px);
    }

    html { height: auto; scroll-behavior: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto !important; }

    body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--sans);
      font-weight: 300;
      overflow-x: hidden;
      cursor: none;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── ORIGINAL CURSOR ── */
    #cursor-dot {
      position: fixed; top: 0; left: 0;
      width: 10px; height: 10px;
      background: var(--fg);
      border-radius: 50%;
      pointer-events: none; z-index: 99999;
      transform: translate(-50%, -50%);
    }
    #cursor-lens {
      position: fixed; top: 0; left: 0;
      width: 120px; height: 120px;
      background: #ffffff;
      border-radius: 50%;
      mix-blend-mode: difference;
      pointer-events: none; z-index: 99998;
      transform: translate(-50%, -50%) scale(0);
      transition: transform 0.6s var(--ease);
    }
    .lens-active #cursor-lens { transform: translate(-50%, -50%) scale(1); }
    .lens-active #cursor-dot  { opacity: 0; }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.9s var(--ease), transform 0.9s var(--ease);
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── NOISE OVERLAY ── */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: -1;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      background-size: 180px 180px;
      opacity: 0.028;
      pointer-events: none;
    }

    /* ── LOADER ── */
    #loader {
      position: fixed; inset: 0; z-index: 9000;
      background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 24px;
      transition: opacity 0.8s var(--ease);
    }
    #loader.done { opacity: 0; pointer-events: none; }
    .loader-name {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 300;
      letter-spacing: 0.3em;
      color: var(--dim);
      animation: fadeWord 2s var(--ease) forwards;
    }
    .loader-line {
      width: 1px; height: 0;
      background: var(--accent);
      animation: growLine 1.8s var(--ease) forwards;
    }
    @keyframes growLine { to { height: 48px; } }
    @keyframes fadeWord { 0%{opacity:0} 60%{opacity:1} 100%{opacity:0.5} }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 28px var(--pad);
      transition: background 0.6s var(--ease), backdrop-filter 0.6s var(--ease);
    }
    nav.scrolled {
      background: rgba(10,10,11,0.75);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-bottom: 1px solid var(--glass-b);
    }
    .nav-mark {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.18em;
      color: var(--dim);
    }
    .nav-status {
      display: flex; align-items: center; gap: 10px;
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      color: var(--accent);
    }
    .pulse {
      width: 6px; height: 6px;
      background: var(--accent); border-radius: 50%;
      animation: pulse 2.4s infinite;
      flex-shrink: 0;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; box-shadow: 0 0 0 0 rgba(229,83,61,0.5); }
      50%      { opacity: 0.7; box-shadow: 0 0 0 6px rgba(229,83,61,0); }
    }
    .nav-link {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      color: var(--dim);
      text-decoration: none;
      transition: color 0.3s;
    }
    .nav-link:hover { color: var(--fg); }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .hero-l {
      display: flex; flex-direction: column;
      justify-content: flex-end;
      padding: 0 56px 72px var(--pad);
      border-right: 1px solid var(--glass-b);
    }
    .hero-eyebrow {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--dim2);
      margin-bottom: 36px;
    }
    .hero-name {
      font-family: var(--serif);
      font-size: clamp(4.5rem, 9vw, 8.5rem);
      font-weight: 300;
      line-height: 0.9;
      letter-spacing: -0.01em;
      margin-bottom: 52px;
    }
    .hero-name em {
      display: block;
      font-style: italic;
      font-weight: 300;
      color: var(--dim);
    }
    .hero-glass {
      background: var(--glass-bg);
      border: 1px solid var(--glass-b);
      border-top-color: var(--glass-bt);
      border-radius: 10px;
      padding: 24px 28px;
      max-width: 400px;
    }
    .hero-glass p {
      font-size: 1rem;
      line-height: 1.75;
      color: var(--dim);
      font-weight: 300;
    }

    /* RIGHT — portrait, original grayscale→color on hover */
    .hero-r { position: relative; overflow: hidden; }
    .hero-r img {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center top;
      filter: grayscale(100%);
      display: block;
      transition: filter 1.2s var(--ease);
    }
    .hero-r:hover img { filter: grayscale(0%); }
    .hero-r-fade {
      position: absolute; inset: 0;
      background: linear-gradient(to bottom,
        var(--bg) 0%, transparent 18%,
        transparent 72%, var(--bg) 100%);
      pointer-events: none;
    }
    .hero-r-fade-left {
      position: absolute; inset: 0;
      background: linear-gradient(to right, var(--bg) 0%, transparent 30%);
      pointer-events: none;
    }
    .hero-r-meta {
      position: absolute; bottom: 48px; right: 36px; left: 36px;
      display: flex; justify-content: space-between; align-items: flex-end;
    }
    .hero-r-meta span {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.16em;
      color: var(--dim2);
      line-height: 1.7;
    }

    /* ── STATEMENT ── */
    .statement {
      padding: clamp(80px,14vh,160px) var(--pad);
      border-top: 1px solid var(--glass-b);
      border-bottom: 1px solid var(--glass-b);
    }
    .statement-label {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      color: var(--accent);
      margin-bottom: 44px;
      display: block;
    }
    .statement-text {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 3.2vw, 3rem);
      font-weight: 300;
      line-height: 1.38;
      color: var(--dim);
      max-width: 820px;
      letter-spacing: 0.01em;
    }
    .statement-text strong { color: var(--fg); font-weight: 400; }

    /* ── STATS ── */
    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      border-bottom: 1px solid var(--glass-b);
    }
    .stat {
      padding: clamp(36px,6vh,64px) var(--pad);
      border-right: 1px solid var(--glass-b);
    }
    .stat:last-child { border-right: none; }
    .stat-n {
      font-family: var(--serif);
      font-size: clamp(2.4rem, 4vw, 3.6rem);
      font-weight: 300;
      line-height: 1;
      margin-bottom: 12px;
    }
    .stat-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      color: var(--dim);
      text-transform: uppercase;
      line-height: 1.65;
    }

    /* ── PROJECTS — each project is its own full-width row ── */
    .projects { border-bottom: 1px solid var(--glass-b); }
    .projects-header {
      display: flex; align-items: baseline; justify-content: space-between;
      padding: 32px var(--pad);
      border-bottom: 1px solid var(--glass-b);
    }
    .projects-header-label {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.22em;
      color: var(--accent);
    }
    .projects-header-count {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      color: var(--dim2);
    }

    .proj {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--glass-b);
      text-decoration: none;
      color: inherit;
      cursor: none;
      min-height: 360px;
    }
    .proj:last-child { border-bottom: none; }

    /* Alternate image side each row */
    .proj:nth-child(even) .proj-img  { order: 2; }
    .proj:nth-child(even) .proj-body { order: 1; }

    .proj-img {
      overflow: hidden;
      position: relative;
    }
    .proj-img img {
      width: 100%; height: 100%;
      object-fit: cover;
      filter: grayscale(100%) brightness(0.75);
      transform: scale(1.05);
      transition: filter 1s var(--ease), transform 1s var(--ease);
      display: block;
    }
    .proj:hover .proj-img img {
      filter: grayscale(0%) brightness(0.92);
      transform: scale(1);
    }

    .proj-body {
      padding: clamp(48px,7vh,88px) clamp(40px,5vw,80px);
      display: flex; flex-direction: column;
      justify-content: center;
      gap: 18px;
      border-left: 1px solid var(--glass-b);
    }
    .proj:nth-child(even) .proj-body {
      border-left: none;
      border-right: 1px solid var(--glass-b);
    }

    .proj-row {
      display: flex; align-items: baseline;
      justify-content: space-between;
    }
    .proj-meta {
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      color: var(--accent);
    }
    .proj-type {
      font-family: var(--mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      color: var(--dim2);
    }
    .proj-title {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 2.8vw, 2.2rem);
      font-weight: 400;
      line-height: 1.15;
    }
    .proj-desc {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--dim);
      font-weight: 300;
      max-width: 400px;
    }
    .proj-arrow {
      display: inline-block;
      font-family: var(--mono);
      font-size: 0.78rem;
      color: var(--dim2);
      margin-top: 8px;
      transition: color 0.3s, transform 0.4s var(--ease);
    }
    .proj:hover .proj-arrow {
      color: var(--accent);
      transform: translate(5px, -5px);
    }

    /* ── CONTACT ── */
    .contact {
      padding: clamp(80px,16vh,180px) var(--pad) clamp(56px,10vh,96px);
    }
    .contact-eyebrow {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      color: var(--dim);
      margin-bottom: 40px;
      display: block;
    }
    /* Email and socials at same visual scale */
    .contact-email {
      font-family: var(--serif);
      font-size: clamp(2rem, 5vw, 4.5rem);
      font-weight: 300;
      letter-spacing: -0.01em;
      color: var(--fg);
      text-decoration: none;
      display: block;
      line-height: 1.1;
      margin-bottom: 20px;
      transition: color 0.4s;
    }
    .contact-email:hover { color: var(--accent); }
    .contact-socials {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 72px;
    }
    .contact-socials a {
      font-family: var(--serif);
      font-size: clamp(1.6rem, 3.6vw, 3.2rem);
      font-weight: 300;
      letter-spacing: -0.01em;
      color: var(--dim);
      text-decoration: none;
      display: block;
      line-height: 1.1;
      transition: color 0.4s;
    }
    .contact-socials a:hover { color: var(--fg); }
    .contact-bottom {
      display: flex; align-items: center;
      justify-content: flex-end;
      padding-top: 32px;
      border-top: 1px solid var(--glass-b);
    }
    .contact-copy {
      font-family: var(--mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      color: var(--dim2);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 860px) {
      body { cursor: auto; }
      #cursor-dot, #cursor-lens { display: none; }
      .hero { grid-template-columns: 1fr; min-height: auto; }
      .hero-l {
        padding: 120px var(--pad) 56px;
        border-right: none;
        border-bottom: 1px solid var(--glass-b);
      }
      .hero-r { min-height: 65vw; }
      .hero-r-fade-left { display: none; }
      .stats { grid-template-columns: 1fr 1fr; }
      .stat:nth-child(2) { border-right: none; }
      .stat:nth-child(3) { border-top: 1px solid var(--glass-b); }
      .stat:nth-child(4) { border-top: 1px solid var(--glass-b); border-right: none; }
      .proj { grid-template-columns: 1fr; min-height: auto; }
      .proj:nth-child(even) .proj-img  { order: 0; }
      .proj:nth-child(even) .proj-body { order: 0; }
      .proj-img { min-height: 56vw; }
      .proj-body { border-left: none !important; border-right: none !important; }
    }
    @media (max-width: 540px) {
      .contact-email { font-size: clamp(1.4rem, 7vw, 2rem); word-break: break-all; }
      .contact-socials a { font-size: clamp(1.1rem, 5vw, 1.6rem); }
      ::-webkit-scrollbar { width: 0; }
    }
  </style>
</head>
<body>

  <div id="loader">
    <div class="loader-line"></div>
    <span class="loader-name">VEDANT CHOLKAR</span>
  </div>

  <div id="cursor-lens"></div>
  <div id="cursor-dot"></div>

  <nav id="nav">
    <span class="nav-mark">VEDANT CHOLKAR - 2026</span>
    <div class="nav-status">
      <span class="pulse"></span>
      CYBERSECURITY RESEARCHER
    </div>
    <a href="mailto:vedantcholkar@gmail.com" class="nav-link lens-target">CONNECT</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-l">
