    <p class="statement-text reveal" style="transition-delay:0.12s">
      Expertise in <strong>web application security</strong> and penetration testing.
      Proficient in <strong>Python, Bash, and C</strong>.
      Driven by curiosity, defined by the work.
    </p>
  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat reveal">
      <div class="stat-n">50+</div>
      <div class="stat-label">CS50x<br>Projects</div>
    </div>
    <div class="stat reveal" style="transition-delay:0.08s">
      <div class="stat-n">8</div>
      <div class="stat-label">OWASP Labs<br>Completed</div>
    </div>
    <div class="stat reveal" style="transition-delay:0.16s">
      <div class="stat-n">2</div>
      <div class="stat-label">Harvard<br>Certifications</div>
    </div>
    <div class="stat reveal" style="transition-delay:0.24s">
      <div class="stat-n">30</div>
      <div class="stat-label">Day AI<br>Internship</div>
    </div>
  </div>

  <!-- PROJECTS -->
