  <script>
    /* ── LOADER ── */
    window.addEventListener('load', () => {
      setTimeout(() => {
        const l = document.getElementById('loader');
        l.classList.add('done');
        setTimeout(() => l.remove(), 900);
      }, 1800);
    });

    /* ── LENIS SMOOTH SCROLL ── */
    const lenis = new Lenis({
      duration: 1.4,
      easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    /* ── NAV SCROLL STATE ── */
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }, { passive: true });

    /* ── ORIGINAL CURSOR: dot + mix-blend lens ── */
    const dot  = document.getElementById('cursor-dot');
    const lens = document.getElementById('cursor-lens');
    let mouseX = -100, mouseY = -100, dotX = -100, dotY = -100;

    document.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });

    function updateCursor() {
      dotX += (mouseX - dotX) * 0.2;
      dotY += (mouseY - dotY) * 0.2;
      dot.style.transform  = `translate(calc(${dotX}px - 50%), calc(${dotY}px - 50%))`;
      lens.style.transform = `translate(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%)) scale(${document.body.classList.contains('lens-active') ? 1 : 0})`;
      requestAnimationFrame(updateCursor);
    }
    updateCursor();

    document.querySelectorAll('.lens-target').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('lens-active'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('lens-active'));
    });

    /* ── SCROLL REVEAL ── */
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
