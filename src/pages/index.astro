      <div class="hero-r-fade"></div>
      <div class="hero-r-fade-left"></div>
      <div class="hero-r-meta">
        <span>CYBERSECURITY<br>RESEARCHER</span>
        <span>BENGALURU<br>INDIA</span>
      </div>
    </div>
  </section>

  <!-- STATEMENT -->
