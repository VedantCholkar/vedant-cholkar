    <a class="proj reveal lens-target" href="#" target="_blank">
      <div class="proj-img">
        <img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964054/quantum_iamuuv.png" alt="Quantum vs Classical" loading="lazy" />
      </div>
      <div class="proj-body">
        <div class="proj-row">
          <span class="proj-meta">06</span>
          <span class="proj-type">ENCRYPTION</span>
