---
// index.astro — Dossier (Complete Final Build: Hero, About, Projects, Contact)
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vedant // Dossier</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;800&family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  
  <script src="https://unpkg.com/@studio-freight/lenis@1.0.39/dist/lenis.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #050505;
      --fg: #f4f4f0;
      --accent: #A7C080; 
      
      --font-massive: 'Syne', sans-serif;
      --font-mono: 'Space Mono', monospace;
      --font-sans: 'Inter', sans-serif;
    }

    html { 
      scroll-behavior: auto; 
    }

    body {
      width: 100%;
      /* Use 'clip' instead of 'hidden'. This stops horizontal scrolling without freezing vertical scroll */
      overflow-x: clip; 
      overflow-y: auto;
      background: var(--bg);
      color: var(--fg);
      -webkit-font-smoothing: antialiased;
    }

    /* Lenis Boilerplate: Prevents the script from locking the viewport */
    html.lenis, html.lenis body {
      height: auto;
    }
    .lenis.lenis-smooth {
      scroll-behavior: auto !important;
    }
    .lenis.lenis-stopped {
      overflow: hidden;
    }

    /* ─── 1. LOADER ─── */
    #loader { position: fixed; inset: 0; background: var(--bg); z-index: 100; display: flex; flex-direction: column; justify-content: center; align-items: center; transition: transform 0.8s cubic-bezier(0.8, 0, 0.2, 1); }
    .loader-text { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 2rem; color: var(--fg); }
    .progress-track { width: 250px; height: 2px; background: rgba(255, 255, 255, 0.1); position: relative; overflow: hidden; }
    .progress-fill { position: absolute; top: 0; left: 0; height: 100%; width: 0%; background: var(--fg); transition: width 0.1s linear; }

    /* ─── 2. HERO SECTION ─── */
    .hero-container { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; flex-direction: column; justify-content: center; overflow: hidden; z-index: 1; will-change: transform; }
    .bg-parallax-wrapper { position: absolute; inset: -50px; z-index: 1; overflow: hidden; }
    .bg-image { position: absolute; inset: 0; background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop'); background-size: cover; background-position: center; transform: scale(1.1); transition: transform 0.1s ease-out, filter 3s ease; will-change: transform; filter: blur(10px) brightness(0); }
    .hero-container.loaded .bg-image { filter: blur(0px) brightness(1); }
    .bg-gradient { position: absolute; inset: 0; z-index: 2; background: linear-gradient(90deg, rgba(5,5,5,0.95) 0%, rgba(5,5,5,0.7) 40%, rgba(5,5,5,0.2) 100%); pointer-events: none; }

    .content-wrapper { position: relative; z-index: 10; padding: 0 5vw; margin-top: -5vh; pointer-events: none; will-change: opacity; }
    .name-container { pointer-events: auto; display: flex; flex-direction: column; max-width: 90vw; margin: 0 auto; cursor: crosshair; }
    .first-name, .last-name { font-family: var(--font-massive); font-weight: 800; font-size: clamp(3rem, 11vw, 11.5rem); line-height: 0.85; text-transform: uppercase; letter-spacing: -0.03em; white-space: nowrap; }
    .first-name { align-self: flex-start; color: var(--fg); transition: color 0.6s ease, letter-spacing 0.6s cubic-bezier(0.19, 1, 0.22, 1), text-shadow 0.6s ease; }
    .first-name:hover { color: var(--accent); letter-spacing: 0.015em; text-shadow: 0 0 25px rgba(167, 192, 128, 0.3); }
    .last-name { align-self: flex-end; color: transparent; -webkit-text-stroke: 1.5px var(--fg); transition: color 0.4s ease, -webkit-text-stroke 0.4s ease, transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .last-name:hover { color: var(--fg); -webkit-text-stroke: 1.5px transparent; transform: translateX(15px); }
    
    .hero-desc { margin-top: 2rem; align-self: flex-end; margin-right: clamp(1rem, 5vw, 4rem); font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; color: rgba(244, 244, 240, 0.8); text-transform: uppercase; font-weight: 700; display: flex; align-items: center; gap: 1rem; }
    .hero-desc::before { content: ''; display: block; width: 30px; height: 1px; background: var(--accent); }

    .ticker-wrap { position: absolute; bottom: 2rem; left: 0; width: 100%; overflow: hidden; background: transparent; z-index: 20; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1); padding: 1rem 0; display: flex; pointer-events: none; will-change: opacity; }
    .ticker { display: flex; white-space: nowrap; animation: ticker-loop 20s linear infinite; }
    .ticker-content { display: flex; flex-shrink: 0; padding-right: 2rem; }
    .ticker-item { padding: 0 2rem; font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(244, 244, 240, 0.7); }
    .ticker-item span { color: var(--accent); }
    @keyframes ticker-loop { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }


    /* ─── 3. ABOUT SECTION ─── */
    .about-section { position: relative; z-index: 10; margin-top: 100vh; width: 100vw; min-height: 120vh; background: radial-gradient(circle at 30% 70%, #0d120a 0%, var(--bg) 60%); display: flex; flex-direction: column; justify-content: center; padding: 15vh 5vw; overflow: hidden; }
    .about-section::before { content: ''; position: absolute; top: -15vh; left: 0; width: 100%; height: 15vh; background: linear-gradient(to bottom, rgba(5,5,5,0) 0%, rgba(5,5,5,1) 100%); pointer-events: none; z-index: 0; }
    .bg-watermark { position: absolute; top: -10vh; left: -2vw; font-family: var(--font-massive); font-size: 45vw; line-height: 0.8; color: rgba(255, 255, 255, 0.03); -webkit-text-stroke: 2px rgba(255, 255, 255, 0.05); z-index: 0; pointer-events: none; will-change: transform; }

    .about-container { position: relative; z-index: 10; display: flex; flex-direction: column; gap: 8rem; width: 100%; max-width: 90vw; margin: 0 auto; }
    .about-top-row { display: flex; justify-content: space-between; align-items: center; gap: 5vw; }
    .manifesto-block { flex: 1.2; }
    .about-label { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase; margin-bottom: 3rem; display: inline-block; border-bottom: 1px solid var(--accent); padding-bottom: 0.5rem; }
    .about-headline { font-family: var(--font-sans); font-weight: 300; font-size: clamp(1.8rem, 3.5vw, 3rem); line-height: 1.3; color: var(--fg); letter-spacing: -0.02em; }
    .about-headline strong { font-family: var(--font-massive); font-weight: 800; font-size: 1.3em; text-transform: uppercase; color: var(--accent); display: block; margin-top: 1rem; letter-spacing: -0.02em; }

    .asset-wrapper { flex: 0.8; display: flex; justify-content: flex-end; position: relative; }
    .asset-card { width: clamp(280px, 25vw, 450px); aspect-ratio: 3/4; border: 1px solid rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; position: relative; will-change: transform; }
    .asset-card::before, .asset-card::after { content: ''; position: absolute; width: 15px; height: 15px; border: 1px solid var(--accent); }
    .asset-card::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
    .asset-card::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
    .asset-placeholder-text { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(244, 244, 240, 0.4); text-transform: uppercase; }
    .rotating-badge { position: absolute; bottom: -3rem; left: -3rem; width: 120px; height: 120px; animation: spin 12s linear infinite; z-index: 20; }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    .about-modules { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 3rem; }
    .module-card { display: flex; flex-direction: column; gap: 1.5rem; padding: 2rem; background: rgba(255, 255, 255, 0.01); border: 1px solid transparent; transition: border-color 0.3s ease, background 0.3s ease; }
    .module-card:hover { border-color: rgba(167, 192, 128, 0.3); background: rgba(255, 255, 255, 0.03); }
    .module-header { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.2em; color: #fff; text-transform: uppercase; display: flex; justify-content: space-between; align-items: center; }
    .module-header span:last-child { color: var(--accent); }
    .module-text { font-family: var(--font-sans); font-size: 0.95rem; line-height: 1.7; color: rgba(244, 244, 240, 0.7); }


    /* ─── 4. PROJECTS GALLERY ─── */
    .projects-section { position: relative; z-index: 10; width: 100vw; background: var(--bg); padding: 15vh 5vw 25vh 5vw; }
    .projects-header { width: 100%; max-width: 90vw; margin: 0 auto 10vh auto; text-align: right; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 2rem; }
    .projects-title { font-family: var(--font-massive); font-size: clamp(3rem, 6vw, 6rem); font-weight: 800; text-transform: uppercase; color: var(--fg); letter-spacing: -0.02em; }
    
    .projects-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4vw; width: 100%; max-width: 90vw; margin: 0 auto; align-items: flex-start; }
    .grid-column { display: flex; flex-direction: column; gap: 4vw; }
    .grid-column.right { margin-top: 15vh; will-change: transform; }

    .project-card { display: flex; flex-direction: column; gap: 1.5rem; cursor: pointer; }
    .project-card:hover .project-image { transform: scale(1.05); }
    .project-image-container { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: #0a0a0a; position: relative; }
    .project-image { width: 100%; height: 100%; background: radial-gradient(circle at center, rgba(255,255,255,0.05) 0%, transparent 70%); transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1); display: flex; align-items: center; justify-content: center; }
    .project-meta { display: flex; flex-direction: column; gap: 0.5rem; }
    .project-tag { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase; }
    .project-name { font-family: var(--font-sans); font-size: 1.5rem; font-weight: 400; color: var(--fg); letter-spacing: -0.01em; transition: color 0.3s ease; }
    .project-card:hover .project-name { color: var(--accent); }


    /* ─── 5. CONTACT / HANDSHAKE SECTION (NEW) ─── */
    .contact-section {
      position: relative;
      z-index: 10;
      width: 100vw;
      background: var(--bg);
      padding: 10vh 5vw 5vh 5vw;
      border-top: 1px solid rgba(255,255,255,0.05);
    }

    .contact-container {
      width: 100%;
      max-width: 90vw;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 10vh;
    }

    .contact-header {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .contact-headline {
      font-family: var(--font-sans);
      font-size: clamp(2rem, 4vw, 4rem);
      font-weight: 300;
      color: var(--fg);
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .contact-links-wrapper {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
    }

    /* Magnetic Container */
    .magnetic-wrap {
      display: inline-block;
      padding: 2rem; /* Creates a larger hit area for the magnet effect */
      margin: -2rem; /* Offsets the padding visually */
    }

    .magnetic-text {
          display: inline-block;
          font-family: var(--font-massive);
          /* Scaled down the vw unit so an 18-character string fits flawlessly */
          font-size: clamp(1.5rem, 4vw, 5rem); 
          font-weight: 800;
          color: var(--fg);
          text-transform: uppercase;
          text-decoration: none;
          letter-spacing: -0.03em;
          line-height: 0.9;
          /* Ensures it wraps cleanly on tiny mobile screens instead of breaking horizontal scroll */
          word-break: break-word; 
          transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
          will-change: transform;
        }

    .social-row {
      display: flex;
      gap: 4vw;
      margin-top: 2rem;
    }

    .social-text {
      font-family: var(--font-mono);
      font-size: clamp(1rem, 2vw, 1.5rem);
      color: rgba(244, 244, 240, 0.6);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: color 0.3s ease;
    }

    .social-text:hover { color: var(--accent); }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      border-top: 1px solid rgba(255,255,255,0.1);
      padding-top: 2rem;
      margin-top: 10vh;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      color: rgba(244,244,240,0.4);
      text-transform: uppercase;
    }

    /* Scroll Reveal Classes */
    .reveal-elem { opacity: 0; transform: translateY(30px); transition: opacity 1s cubic-bezier(0.19, 1, 0.22, 1), transform 1s cubic-bezier(0.19, 1, 0.22, 1); }
    .reveal-elem.is-visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 900px) {
        /* ─── GLOBAL MOBILE LOCK ─── */
        body, html { overflow-x: clip !important; }

        /* ─── HERO RECALIBRATION ─── */
        .name-container { margin: 0; align-items: flex-start; }
        .first-name, .last-name { font-size: clamp(2.5rem, 11vw, 4rem) !important; align-self: flex-start !important; }
        .last-name { margin-left: 1.5rem !important; }
        .hero-desc { align-self: flex-start !important; margin-right: 0 !important; margin-left: 1.5rem !important; flex-direction: column; align-items: flex-start; gap: 0.5rem; margin-top: 1rem; text-align: left; max-width: 80vw; }
        .hero-desc::before { display: none; }

        /* ─── ABOUT RECALIBRATION ─── */
        .about-section { padding: 10vh 5vw; }
        .bg-watermark { font-size: 80vw; top: 0; left: -5vw; }
        .about-top-row { flex-direction: column; align-items: flex-start; gap: 3rem; }
        .about-headline { font-size: clamp(1.5rem, 6vw, 2rem) !important; } 
        .asset-wrapper { width: 100%; justify-content: flex-start; margin-top: 1rem; }
        .about-modules { grid-template-columns: 1fr; gap: 3rem; }

        /* ─── PROJECTS RECALIBRATION (THE ARCHIVE FIX) ─── */
        .projects-header { text-align: left; margin-bottom: 5vh; }
        .projects-title { 
            font-size: clamp(2.5rem, 12vw, 4rem) !important; 
            line-height: 0.9 !important; 
            /* Forces long words to break instead of stretching the screen */
            word-wrap: break-word; 
            overflow-wrap: break-word;
        }
        .projects-grid { grid-template-columns: 1fr; gap: 6vh; }
        .grid-column.right { margin-top: 0; transform: none !important; }

        /* ─── CONTACT RECALIBRATION ─── */
        .contact-headline { font-size: clamp(1.8rem, 8vw, 2.5rem) !important; }
        .magnetic-text { font-size: clamp(1.5rem, 8vw, 3rem) !important; word-break: break-word; line-height: 1; }
        .social-row { flex-direction: column; gap: 1.5rem; }
        .social-text { font-size: 1rem !important; }
        .footer-bottom { flex-direction: column; gap: 1rem; align-items: flex-start; margin-top: 6vh; }
    }
  </style>
</head>
<body>

  <div id="loader">
    <div class="loader-text">Loading Assets</div>
    <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
  </div>

  <main class="hero-container" id="hero">
    <div class="bg-parallax-wrapper"><div class="bg-image" id="bg-parallax"></div></div>
    <div class="bg-gradient"></div>
    <div class="content-wrapper" id="hero-content">
      <div class="name-container">
        <span class="first-name">Vedant</span>
        <span class="last-name">Cholkar</span>
        <div class="hero-desc">System Architecture // Web Reconnaissance</div>
      </div>
    </div>
    <div class="ticker-wrap" id="hero-ticker">
      <div class="ticker">
        <div class="ticker-content">
          <div class="ticker-item">SYS: <span>FEDORA</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">STATUS: <span>ACTIVE RECON</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">ACOUSTIC DYNAMICS</div><div class="ticker-item">///</div>
          <div class="ticker-item">DEST: <span>TOKYO 2026</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">INITIATING AADVIK_TEKLABS</div><div class="ticker-item">///</div>
        </div>
        <div class="ticker-content">
          <div class="ticker-item">SYS: <span>FEDORA</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">STATUS: <span>ACTIVE RECON</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">ACOUSTIC DYNAMICS</div><div class="ticker-item">///</div>
          <div class="ticker-item">DEST: <span>TOKYO 2026</span></div><div class="ticker-item">///</div>
          <div class="ticker-item">INITIATING AADVIK_TEKLABS</div><div class="ticker-item">///</div>
        </div>
      </div>
    </div>
  </main>

  <section class="about-section" id="about">
    <div class="bg-watermark" id="scroll-watermark">01</div>
    <div class="about-container">
      <div class="about-top-row">
        <div class="manifesto-block reveal-elem">
          <span class="about-label">IDENT // V.CHOLKAR</span>
          <h2 class="about-headline">
            Operating out of Bengaluru, driven by a singular baseline:
            <strong>Buy nice,<br>or buy twice.</strong>
            Optimization is not an afterthought; it is the foundation.
          </h2>
        </div>
        <div class="asset-wrapper reveal-elem" style="transition-delay: 0.2s;">
          <div class="asset-card" id="scroll-asset">
            <span class="asset-placeholder-text">[ VISUAL ASSET // PROFILE ]</span>
            <svg class="rotating-badge" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="45" fill="none" stroke="var(--accent)" stroke-width="1" stroke-dasharray="4,6" opacity="0.5"/>
              <circle cx="50" cy="50" r="35" fill="none" stroke="var(--fg)" stroke-width="0.5" opacity="0.3"/>
              <path d="M50 10 L50 20 M50 90 L50 80 M10 50 L20 50 M90 50 L80 50" stroke="var(--accent)" stroke-width="2"/>
            </svg>
          </div>
        </div>
      </div>
      <div class="about-modules">
        <div class="module-card reveal-elem" style="transition-delay: 0.1s;">
          <div class="module-header"><span>[ Module_A ]</span><span>The Architecture</span></div>
          <p class="module-text">A dual discipline. The uncompromising structure of web application reconnaissance, mapping vulnerabilities and executing precise tooling, balanced against the raw physical tension and exact rhythm required for Spanish Flamenco acoustic performance.</p>
        </div>
        <div class="module-card reveal-elem" style="transition-delay: 0.2s;">
          <div class="module-header"><span>[ Module_B ]</span><span>Current Trajectory</span></div>
          <p class="module-text">Executing hardware and system optimizations on Fedora Linux. Currently preparing for active operations at Aadvik Teklabs, alongside a calculated, multi-phase trajectory targeting engineering deployment in Japan via MEXT 2026.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="projects-section" id="projects">
    <div class="projects-header reveal-elem">
      <h2 class="projects-title">Operations<br><span style="color: transparent; -webkit-text-stroke: 1.5px var(--fg);">Archive</span></h2>
    </div>
    <div class="projects-grid">
      <div class="grid-column left">
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 01 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ ALGO // HARVARD ]</span><h3 class="project-name">CS50 Certification</h3></div>
        </div>
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 03 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ APP // DEV ]</span><h3 class="project-name">StudyFlow Platform</h3></div>
        </div>
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 05 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ RECON // LABS ]</span><h3 class="project-name">PortSwigger Academy: 50+</h3></div>
        </div>
      </div>
      <div class="grid-column right" id="projects-col-right">
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 02 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ SEC // HARVARD ]</span><h3 class="project-name">Cybersecurity Certification</h3></div>
        </div>
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 04 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ APP // DEV ]</span><h3 class="project-name">CryptMentor</h3></div>
        </div>
        <div class="project-card reveal-elem">
          <div class="project-image-container"><div class="project-image"><span style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.2);">[ ASSET // 06 ]</span></div></div>
          <div class="project-meta"><span class="project-tag">[ VULN // RESEARCH ]</span><h3 class="project-name">XSS Vulnerability Report</h3></div>
        </div>
      </div>
    </div>
  </section>

  <section class="contact-section" id="contact">
    <div class="contact-container">
      
      <div class="contact-header reveal-elem">
        <span class="about-label">INITIATE // HANDSHAKE</span>
        <h2 class="contact-headline">No forms. No friction.<br>Just direct architecture.</h2>
      </div>

      <div class="contact-links-wrapper reveal-elem">
        <div class="magnetic-wrap">
          <a href="#" class="magnetic-text cipher-link" data-value="vedant@cholkar.dev">vedant@cholkar.dev</a>
        </div>

        <div class="social-row">
          <div class="magnetic-wrap">
            <a href="#" class="social-text cipher-link magnetic-text" data-value="GITHUB // V-CHOLKAR" style="font-size: clamp(1rem, 2vw, 1.5rem);">GITHUB // V-CHOLKAR</a>
          </div>
          <div class="magnetic-wrap">
            <a href="#" class="social-text cipher-link magnetic-text" data-value="LINKEDIN // VEDANT" style="font-size: clamp(1rem, 2vw, 1.5rem);">LINKEDIN // VEDANT</a>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <span>© 2026 // VEDANT CHOLKAR</span>
        <span>SYS. STATUS // OPTIMIZED</span>
        <span id="footer-time">00:00:00 BLR</span>
      </div>

    </div>
  </section>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      // 1. LENIS (Smooth Scroll)
      const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), smoothWheel: true });
      function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      // 2. LOADER & HERO PARALLAX
      const loader = document.getElementById('loader');
      const progressFill = document.getElementById('progress-fill');
      const hero = document.getElementById('hero');
      const bgParallax = document.getElementById('bg-parallax');
      let progress = 0; let isLoaded = false;

      const interval = setInterval(() => {
        progress += Math.floor(Math.random() * 20) + 10;
        if (progress >= 100) {
          progress = 100; clearInterval(interval);
          setTimeout(() => {
            loader.style.transform = 'translateY(-100%)';
            setTimeout(() => {
              loader.style.display = 'none';
              hero.classList.add('loaded');
              bgParallax.style.transform = 'scale(1.05)';
              setTimeout(() => { isLoaded = true; }, 1000);
            }, 800);
          }, 400);
        }
        progressFill.style.width = `${progress}%`;
      }, 100);

      document.addEventListener('mousemove', (e) => {
          if (!isLoaded) return; 
          const x = (e.clientX / window.innerWidth - 0.5) * 35; 
          const y = (e.clientY / window.innerHeight - 0.5) * 35; 
          bgParallax.style.transform = `translate(${x}px, ${y}px) scale(1.05)`;
      });

      // 3. SCROLL REVEALS
      const revealElements = document.querySelectorAll('.reveal-elem');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) { entry.target.classList.add('is-visible'); }
        });
      }, { threshold: 0.1 }); 
      revealElements.forEach(el => observer.observe(el));

      // 4. SCROLL PARALLAX (Curtain, About, Projects)
      const watermark = document.getElementById('scroll-watermark');
      const assetCard = document.getElementById('scroll-asset');
      const aboutSection = document.getElementById('about');
      const heroContent = document.getElementById('hero-content');
      const heroTicker = document.getElementById('hero-ticker');
      const projectsSection = document.getElementById('projects');
      const rightCol = document.getElementById('projects-col-right');
      
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;

        if (scrollY < windowHeight) {
            const opacity = 1 - (scrollY / (windowHeight * 0.6)); 
            if(heroContent) heroContent.style.opacity = Math.max(0, opacity);
            if(heroTicker) heroTicker.style.opacity = Math.max(0, opacity);
        }

        if (aboutSection) {
            const rect = aboutSection.getBoundingClientRect();
            const scrollProgress = windowHeight - rect.top;
            if (scrollProgress > 0 && rect.top < windowHeight + 500) {
                const watermarkOffset = scrollProgress * 0.35; 
                if(watermark) watermark.style.transform = `translateY(${watermarkOffset}px)`;
                const assetOffset = scrollProgress * -0.15;
                if(assetCard && window.innerWidth > 900) { assetCard.style.transform = `translateY(${assetOffset}px)`; }
            }
        }

        if (projectsSection && rightCol && window.innerWidth > 900) {
            const pRect = projectsSection.getBoundingClientRect();
            const pScrollProgress = windowHeight - pRect.top;
            if (pScrollProgress > 0 && pRect.top < windowHeight + pRect.height) {
                const rightColOffset = pScrollProgress * -0.12; 
                rightCol.style.transform = `translateY(${rightColOffset}px)`;
            }
        }
      });

      // 5. FUN ELEMENT: CIPHER DECRYPT HOVER
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
      const cipherLinks = document.querySelectorAll('.cipher-link');
      
      cipherLinks.forEach(link => {
        link.addEventListener('mouseenter', event => {
          let iterations = 0;
          const targetText = event.target.dataset.value;
          
          clearInterval(link.cipherInterval);
          
          link.cipherInterval = setInterval(() => {
            event.target.innerText = targetText.split("")
              .map((letter, index) => {
                if(index < iterations || letter === " ") return targetText[index];
                return letters[Math.floor(Math.random() * 42)];
              })
              .join("");
            
            if(iterations >= targetText.length){ 
              clearInterval(link.cipherInterval); 
              event.target.style.color = "var(--accent)"; // Pop green when decrypted
            }
            iterations += 1 / 3; // Controls decrypt speed
          }, 30);
        });

        link.addEventListener('mouseleave', event => {
            clearInterval(link.cipherInterval);
            event.target.innerText = event.target.dataset.value;
            event.target.style.color = ""; // Reset color
        });
      });

      // 6. FUN ELEMENT: MAGNETIC PULL
      const magneticWraps = document.querySelectorAll('.magnetic-wrap');
      
      magneticWraps.forEach(wrap => {
        const text = wrap.querySelector('.magnetic-text');
        
        wrap.addEventListener('mousemove', (e) => {
            const rect = wrap.getBoundingClientRect();
            const x = e.clientX - rect.left - rect.width / 2;
            const y = e.clientY - rect.top - rect.height / 2;
            
            // Subtly pull the text toward the mouse pointer
            text.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
        });

        wrap.addEventListener('mouseleave', () => {
            // Snap back to center
            text.style.transform = `translate(0px, 0px)`;
        });
      });

      // 7. FOOTER CLOCK TICKER
      const timeDisplay = document.getElementById('footer-time');
      setInterval(() => {
          const now = new Date();
          timeDisplay.innerText = now.toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour12: false }) + " BLR";
      }, 1000);

    });
  </script>

</body>
</html>