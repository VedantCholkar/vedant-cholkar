---
// index.astro — Dossier (Final Payload: All Projects + Custom Scrollbar + Geometric Unfolding Loader)
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vedant Cholkar — CyberSecurity</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

  <script src="https://unpkg.com/@studio-freight/lenis@1.0.39/dist/lenis.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f1012; 
      --fg: #ffffff;
      --dim: #8b929e;
      --accent: #E5533D; 
      --font-main: 'Plus Jakarta Sans', sans-serif;
      --font-mono: 'Space Mono', monospace;
      --ease-fluid: cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ─── GEOMETRIC UNFOLDING LOADER ─── */
    #loader {
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 1000;
      display: flex;
      justify-content: center;
      align-items: center;
      transition: clip-path 2s var(--ease-fluid);
      clip-path: inset(0 0 0 0);
    }
    .loader-shape {
      width: 50px;
      height: 50px;
      border: 1px solid var(--accent);
      animation: morphRotate 2.5s infinite var(--ease-fluid);
    }
    @keyframes morphRotate {
      0% { border-radius: 0%; transform: rotate(0deg); }
      50% { border-radius: 50%; transform: rotate(180deg); border-color: #fff; }
      100% { border-radius: 0%; transform: rotate(360deg); }
    }

    /* ─── SCROLLBAR ─── */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--accent); }
    * { scrollbar-width: thin; scrollbar-color: rgba(255, 255, 255, 0.1) var(--bg); }

    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto !important; }

    body {
      background-color: var(--bg);
      color: var(--fg);
      font-family: var(--font-main);
      overflow-x: hidden;
      cursor: none;
      -webkit-font-smoothing: antialiased;
    }

    .bg-grid {
      position: fixed;
      top: 0; left: 0; width: 100vw; height: 100vh;
      z-index: -10;
      background-image: radial-gradient(rgba(255, 255, 255, 0.1) 1.5px, transparent 1.5px);
      background-size: 40px 40px;
    }

    #cursor-dot {
      position: fixed; top: 0; left: 0; width: 10px; height: 10px;
      background: var(--fg); border-radius: 50%;
      pointer-events: none; z-index: 99999;
      transform: translate(-50%, -50%);
    }
    #cursor-lens {
      position: fixed; top: 0; left: 0; width: 120px; height: 120px;
      background: #ffffff; border-radius: 50%;
      mix-blend-mode: difference; pointer-events: none; z-index: 99998;
      transform: translate(-50%, -50%) scale(0);
      transition: transform 0.6s var(--ease-fluid);
    }
    .lens-active #cursor-lens { transform: translate(-50%, -50%) scale(1); }
    .lens-active #cursor-dot { opacity: 0; }

    .glass {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 1px solid rgba(255, 255, 255, 0.25);
      border-radius: 12px;
    }

    .container { max-width: 1400px; margin: 0 auto; padding: 0 5vw; }

    /* ─── HERO ─── */
    .hero {
      min-height: 100vh;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 15vh 0;
      gap: 5vw;
    }

    .hero-content { flex: 1.2; }
    .status { 
      color: var(--accent); 
      font-family: var(--font-mono); 
      font-size: 0.8rem; 
      letter-spacing: 0.2em; 
      display: flex; 
      align-items: center; 
      gap: 12px; 
      margin-bottom: 2rem; 
    }
    .status-dot { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; animation: blink 2s infinite; }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    h1 { font-size: clamp(3rem, 9vw, 8rem); font-weight: 800; line-height: 0.9; margin-bottom: 3rem; }
    .hero-manifesto { font-size: 1.2rem; color: var(--dim); line-height: 1.6; max-width: 520px; padding: 2rem; }

    .portrait-wrap { 
      width: clamp(280px, 30vw, 450px); 
      aspect-ratio: 3/4; 
      overflow: hidden; 
      border-radius: 12px; 
      padding: 15px; 
    }
    .portrait-inner { width: 100%; height: 100%; overflow: hidden; border-radius: 8px; }
    .portrait-inner img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%); transition: filter 1.2s var(--ease-fluid); }
    .portrait-wrap:hover .portrait-inner img { filter: grayscale(0%); }

    /* ─── FOCUS ─── */
    .focus { padding: 15vh 0; }
    .focus-text { font-size: clamp(1.2rem, 2.5vw, 2.2rem); font-weight: 300; line-height: 1.5; color: var(--dim); }
    .highlight { color: var(--fg); font-weight: 500; }
    
    .section-label { 
      color: var(--accent); 
      font-family: var(--font-mono); 
      font-size: 0.9rem; 
      margin-bottom: 5rem; 
      display: block; 
      letter-spacing: 0.4em; 
      text-transform: uppercase;
    }

    /* ─── PROJECTS ─── */
    .projects { padding: 15vh 0; }
    .project-grid { 
      display: grid; 
      grid-template-columns: repeat(2, 1fr); 
      gap: 12vh 8vw;
    }
    
    .project-card { padding: 2rem; transition: transform 0.6s var(--ease-fluid); text-decoration: none; color: inherit; cursor: none; }
    .project-card:hover { transform: translateY(-15px); }
    .project-grid > :nth-child(even) { margin-top: 15vh; }

    .img-box { width: 100%; aspect-ratio: 16/10; overflow: hidden; border-radius: 8px; margin-bottom: 2rem; }
    .img-box img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%); transition: filter 0.8s var(--ease-fluid); }
    .project-card:hover .img-box img { filter: grayscale(0%); }
    
    .project-title { font-size: 1.8rem; font-weight: 700; margin-top: 1rem; color: var(--fg); }
    .project-desc { font-size: 1rem; color: var(--dim); line-height: 1.6; margin-top: 1rem; }
    .project-meta { font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.1em; }

    /* ─── FOOTER ─── */
    .contact { padding: 20vh 0; text-align: center; border-top: 1px solid rgba(255,255,255,0.05); }
    .email-box { padding: 2.5rem 2rem; margin-bottom: 4rem; display: inline-block; width: 100%; max-width: 750px; }
    .email-link { 
      font-size: clamp(1.2rem, 3.5vw, 2.5rem); 
      font-weight: 700; 
      color: var(--fg); 
      text-decoration: none;
      white-space: nowrap;
    }
    
    .social-links { display: flex; justify-content: center; align-items: center; gap: 4rem; }
    .social-links a { 
      color: var(--fg); 
      text-decoration: none; 
      font-family: var(--font-main); 
      font-size: clamp(1.2rem, 3vw, 2.5rem); 
      font-weight: 700;
      transition: color 0.4s var(--ease-fluid); 
    }
    .social-links a:hover { color: var(--accent); }

    @media (max-width: 900px) {
      body { cursor: auto; }
      #cursor-dot, #cursor-lens { display: none; }
      .hero { flex-direction: column-reverse; align-items: center; text-align: center; padding: 10vh 0 15vh 0; }
      .hero-content { width: 100%; margin-top: 5vh; }
      .status { justify-content: center; flex-direction: row-reverse; } 
      .hero-manifesto { margin: 0 auto; border-left: none; border-top: 2px solid rgba(255,255,255,0.1); padding: 2.5rem 1rem; }
      .portrait-wrap { width: 180px; aspect-ratio: 1/1; border-radius: 50%; padding: 8px; margin: 0 auto; }
      .portrait-inner { border-radius: 50%; }
      .project-grid { grid-template-columns: 1fr; gap: 10vh; }
      .project-grid > :nth-child(even) { margin-top: 0; }
      .contact { padding: 15vh 5vw; }
      .social-links { flex-direction: column; gap: 2.5rem; }
      .email-link { white-space: normal; word-break: break-all; }
      ::-webkit-scrollbar { width: 0; } 
    }
  </style>
</head>
<body>

  <!-- GEOMETRIC UNFOLDING LOADER -->
  <div id="loader">
    <div class="loader-shape"></div>
  </div>

  <div class="bg-grid"></div>
  <div id="cursor-lens"></div>
  <div id="cursor-dot"></div>

  <main class="container">
    
    <section class="hero">
      <div class="hero-content">
        <div class="status">
          CYBERSECURITY RESEARCHER
          <span class="status-dot"></span>
        </div>
        <h1>Vedant Cholkar.</h1>
        <div class="hero-manifesto glass">
          <p>Securing the world for a safer web. Driven by passion, defined by hard work, and determined to succeed.</p>
        </div>
      </div>
      <div class="hero-image">
        <div class="portrait-wrap glass lens-target">
          <div class="portrait-inner">
            <img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964054/suitpfp_qpkyok.png" alt="Vedant Cholkar" />
          </div>
        </div>
      </div>
    </section>

    <section class="focus">
      <span class="section-label">FOCUS</span>
      <p class="focus-text">
        Expertise in <span class="highlight">Web Application Security</span>, penetration testing, and secure network configuration. Proficient in <span class="highlight">Python, Bash, and C</span> with a focus on AI/LLM optimization.
      </p>
    </section>

    <section class="projects">
      <span class="section-label">OPERATIONS ARCHIVE</span>
      <div class="project-grid">
        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964053/cryptmentor_swt0at.png" alt="CryptMentor" /></div>
          <span class="project-meta">01 // APP // FINTECH</span>
          <h3 class="project-title">CryptMentor Simulator</h3>
          <p class="project-desc">A fully functional simulation of the cryptocurrency market to provide insight for new investors in the workings of cyber exchange.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964056/studyflow_fnidst.png" alt="StudyFlow" /></div>
          <span class="project-meta">02 // APP // DEV</span>
          <h3 class="project-title">StudyFlow Platform</h3>
          <p class="project-desc">Web app containing tools useful for students, including pomodoro timers, integration with google calendar, stress exercises, and much more.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964053/cs50x_y4cue1.png" alt="CS50x" /></div>
          <span class="project-meta">03 // CERT // HARVARD</span>
          <h3 class="project-title">CS50x Computer Science</h3>
          <p class="project-desc">An official course by University of Harvard Online, where over 50+ projects were done, all available on GitHub, setting a foundation for all of computer science.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964052/cs50_cybersec_mqrprp.jpg" alt="CS50 CyberSec" /></div>
          <span class="project-meta">04 // CERT // HARVARD</span>
          <h3 class="project-title">CS50 Cybersecurity</h3>
          <p class="project-desc">Introduction into CyberSecurity by Harvard Online, with graded topic essays deepening the understanding of web security.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964052/aadvik_x5u2ib.jpg" alt="Aadvik" /></div>
          <span class="project-meta">05 // AI // AUTOMATION</span>
          <h3 class="project-title">Aadvik TekLabs Workflow</h3>
          <p class="project-desc">Executed a 30-day intensive technical internship centered on AI Workflow Automation Tools.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964054/quantum_iamuuv.png" alt="Quantum" /></div>
          <span class="project-meta">06 // SEC // ENCRYPTION</span>
          <h3 class="project-title">Quantum vs Classical Cipher</h3>
          <p class="project-desc">A web app showing the different relative strengths of encryption and dangers possessed by quantum computing in breaking them against classical computers.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964054/onlyoffice_rmzjq7.jpg" alt="OnlyOffice" /></div>
          <span class="project-meta">07 // SEC // RESEARCH</span>
          <h3 class="project-title">OnlyOffice XSS Deep-Dive</h3>
          <p class="project-desc">A research presentation on how exactly a XSS is achieved in the web application, as a final project for Harvard Online.</p>
        </div>

        <div class="project-card glass">
          <div class="img-box lens-target"><img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964052/portswigger_nktm5s.png" alt="PortSwigger" /></div>
          <span class="project-meta">08 // RECON // LABS</span>
          <h3 class="project-title">PortSwigger Labs</h3>
          <p class="project-desc">Deep understanding of web exploits after breaking labs across a broad spectrum of topics, including OWASP Top 10 vulnerabilities.</p>
        </div>
      </div>
    </section>

    <footer class="contact">
      <span class="section-label">CONNECT FOR WEB TESTING / TO BUILD PROJECTS</span>
      <div class="email-box glass lens-target">
        <a href="javascript:void(0)" class="email-link">vedantcholkar@gmail.com</a>
      </div>
      <div class="social-links">
        <a href="javascript:void(0)">GitHub</a>
        <a href="javascript:void(0)">LinkedIn</a>
      </div>
    </footer>
  </main>

  <script>
    // GEOMETRIC REVEAL LOADER LOGIC
    window.addEventListener('load', () => {
      const loader = document.getElementById('loader');
      setTimeout(() => {
        // "Unfolds" the page vertically
        loader.style.clipPath = 'inset(0 0 100% 0)';
      }, 2000);
    });

    // SMOOTH SCROLL
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // CURSOR
    const dot = document.getElementById('cursor-dot');
    const lens = document.getElementById('cursor-lens');
    let mouseX = -100, mouseY = -100, dotX = -100, dotY = -100;

    document.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

    function updateCursor() {
      dotX += (mouseX - dotX) * 0.2;
      dotY += (mouseY - dotY) * 0.2;
      dot.style.transform = `translate(calc(${dotX}px - 50%), calc(${dotY}px - 50%))`;
      lens.style.transform = `translate(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%)) scale(${document.body.classList.contains('lens-active') ? 1 : 0})`;
      requestAnimationFrame(updateCursor);
    }
    updateCursor();

    document.querySelectorAll('.lens-target').forEach(el => {
      el.addEventListener('mouseenter', () => document.body.classList.add('lens-active'));
      el.addEventListener('mouseleave', () => document.body.classList.remove('lens-active'));
    });
  </script>
</body>
</html>