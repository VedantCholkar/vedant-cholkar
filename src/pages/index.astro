    <a class="proj reveal lens-target" href="#" target="_blank">
      <div class="proj-img">
        <img src="https://res.cloudinary.com/df6yxni8e/image/upload/f_auto,q_auto/v1777964052/aadvik_x5u2ib.jpg" alt="Aadvik TekLabs" loading="lazy" />
      </div>
      <div class="proj-body">
        <div class="proj-row">
          <span class="proj-meta">05</span>
          <span class="proj-type">AI / AUTOMATION</span>
        </div>
        <h3 class="proj-title">Aadvik TekLabs</h3>
        <p class="proj-desc">30-day intensive internship in AI workflow automation tools and applied machine learning pipelines.</p>
        <span class="proj-arrow">↗</span>
      </div>
