  <script>
    document.addEventListener("DOMContentLoaded", () => {
      
      const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), smoothWheel: true });
      function raf(time) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      const cursorDot = document.querySelector('.cursor-dot');
      const cursorRing = document.getElementById('cursor-ring');
      let mouseX = 0, mouseY = 0;
      let ringX = 0, ringY = 0;

      if (window.innerWidth > 900) {
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX; mouseY = e.clientY;
          cursorDot.style.transform = `translate(calc(${mouseX}px - 50%), calc(${mouseY}px - 50%))`;
        });

        const renderCursor = () => {
          ringX += (mouseX - ringX) * 0.15; ringY += (mouseY - ringY) * 0.15;
          cursorRing.style.transform = `translate(calc(${ringX}px - 50%), calc(${ringY}px - 50%))`;
          requestAnimationFrame(renderCursor);
        };
        requestAnimationFrame(renderCursor);

        const hoverTargets = document.querySelectorAll('.hover-target, a, button');
        hoverTargets.forEach(target => {
          target.addEventListener('mouseenter', () => document.getElementById('tactical-cursor').classList.add('cursor-hover'));
          target.addEventListener('mouseleave', () => document.getElementById('tactical-cursor').classList.remove('cursor-hover'));
        });
      }

      const loader = document.getElementById('loader');
      const progressFill = document.getElementById('progress-fill');
      const hero = document.getElementById('hero');
      const bgParallax = document.getElementById('bg-parallax');
      let progress = 0; let isLoaded = false;

      const interval = setInterval(() => {
        progress += Math.floor(Math.random() * 20) + 10;
        if (progress >= 100) {
          progress = 100; clearInterval(interval);
          setTimeout(() => {
            loader.style.transform = 'translateY(-100%)';
            setTimeout(() => {
              loader.style.display = 'none'; hero.classList.add('loaded');
              setTimeout(() => { isLoaded = true; }, 1000);
            }, 800);
          }, 400);
        }
        progressFill.style.width = `${progress}%`;
      }, 100);

      document.addEventListener('mousemove', (e) => {
          if (!isLoaded || window.innerWidth <= 900) return; 
          const x = (e.clientX / window.innerWidth - 0.5) * 35; 
          const y = (e.clientY / window.innerHeight - 0.5) * 35; 
          bgParallax.style.transform = `translate(${x}px, ${y}px)`;
      });

      const revealElements = document.querySelectorAll('.reveal-elem');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('is-visible'); });
      }, { threshold: 0.1 }); 
      revealElements.forEach(el => observer.observe(el));

      const watermark = document.getElementById('scroll-watermark');
      const assetCard = document.getElementById('scroll-asset');
      const aboutSection = document.getElementById('about');
      const heroContent = document.getElementById('hero-content');
      const heroTicker = document.getElementById('hero-ticker');
      const projectsSection = document.getElementById('projects');
      const rightCol = document.getElementById('projects-col-right');
      
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY; const windowHeight = window.innerHeight;

        if (scrollY < windowHeight) {
            const opacity = 1 - (scrollY / (windowHeight * 0.6)); 
            if(heroContent) heroContent.style.opacity = Math.max(0, opacity);
            if(heroTicker) heroTicker.style.opacity = Math.max(0, opacity);
        }

        if (aboutSection) {
            const rect = aboutSection.getBoundingClientRect(); const scrollProgress = windowHeight - rect.top;
            if (scrollProgress > 0 && rect.top < windowHeight + 500) {
                if(watermark) watermark.style.transform = `translateY(${scrollProgress * 0.35}px)`;
                if(assetCard && window.innerWidth > 900) assetCard.style.transform = `translateY(${scrollProgress * -0.15}px)`; 
            }
        }

        if (projectsSection && rightCol && window.innerWidth > 900) {
            const pRect = projectsSection.getBoundingClientRect(); const pScrollProgress = windowHeight - pRect.top;
            if (pScrollProgress > 0 && pRect.top < windowHeight + pRect.height) {
                rightCol.style.transform = `translateY(${pScrollProgress * -0.12}px)`;
            }
        }
      });

      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
      const cipherLinks = document.querySelectorAll('.cipher-link');
      
      cipherLinks.forEach(link => {
        link.addEventListener('mouseenter', event => {
          let iterations = 0; const targetText = event.target.dataset.value;
          clearInterval(link.cipherInterval);
          link.cipherInterval = setInterval(() => {
            event.target.innerText = targetText.split("").map((letter, index) => {
                if(index < iterations || letter === " ") return targetText[index];
                return letters[Math.floor(Math.random() * 42)];
              }).join("");
            if(iterations >= targetText.length){ clearInterval(link.cipherInterval); event.target.style.color = "var(--accent)"; }
            iterations += 1 / 3; 
          }, 30);
        });
        link.addEventListener('mouseleave', event => {
            clearInterval(link.cipherInterval);
            event.target.innerText = event.target.dataset.value;
            event.target.style.color = ""; 
        });
      });

      const magneticWraps = document.querySelectorAll('.magnetic-wrap');
      magneticWraps.forEach(wrap => {
        if (window.innerWidth > 900) {
          const text = wrap.querySelector('.magnetic-text');
          wrap.addEventListener('mousemove', (e) => {
              const rect = wrap.getBoundingClientRect();
              const x = e.clientX - rect.left - rect.width / 2;
              const y = e.clientY - rect.top - rect.height / 2;
              text.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
          });
          wrap.addEventListener('mouseleave', () => text.style.transform = `translate(0px, 0px)`);
        }
      });

      const timeDisplay = document.getElementById('footer-time');
      setInterval(() => {
          const now = new Date();
          timeDisplay.innerText = now.toLocaleTimeString('en-IN', { timeZone: 'Asia/Kolkata', hour12: false }) + " BLR";
      }, 1000);

    });
  </script>

